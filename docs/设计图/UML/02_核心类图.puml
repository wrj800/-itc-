@startuml
skinparam classAttributeIconSize 0

class User {
  +Long id
  +String username
  +String password
  +String realName
  +String status
}

class Role {
  +Long id
  +String roleCode
  +String roleName
}

class Device {
  +Long id
  +String deviceCode
  +String deviceName
  +String deviceType
  +String ipAddress
  +String location
  +String manager
  +String status
}

class DeviceMetric {
  +Long id
  +Long deviceId
  +BigDecimal cpuUsage
  +BigDecimal memoryUsage
  +BigDecimal diskUsage
  +String onlineStatus
  +LocalDateTime collectedTime
}

class AlarmRecord {
  +Long id
  +Long deviceId
  +String alarmTitle
  +String alarmLevel
  +String alarmType
  +String status
}

class WorkOrder {
  +Long id
  +String orderNo
  +Long alarmId
  +String title
  +String priority
  +Long assigneeId
  +String status
}

class WorkOrderLog {
  +Long id
  +Long workOrderId
  +Long operatorId
  +String action
  +String content
}

class LogAnalysisRecord {
  +Long id
  +Long deviceId
  +String riskLevel
  +String faultType
  +String keywords
  +String suggestion
}

class KnowledgeDocument {
  +Long id
  +String fileName
  +String fileType
  +String filePath
  +String parseStatus
  +Integer chunkCount
}

class KnowledgeChunk {
  +Long id
  +Long documentId
  +Integer chunkIndex
  +String content
  +String vectorId
}

class AiQaRecord {
  +Long id
  +Long userId
  +String question
  +String answer
  +String sourceRefs
}

User "many" -- "many" Role : 拥有
Device "1" -- "many" DeviceMetric : 产生
Device "1" -- "many" AlarmRecord : 产生
AlarmRecord "1" -- "0..1" WorkOrder : 转为
WorkOrder "1" -- "many" WorkOrderLog : 包含
Device "1" -- "many" LogAnalysisRecord : 关联
KnowledgeDocument "1" -- "many" KnowledgeChunk : 切分
User "1" -- "many" AiQaRecord : 提问
@enduml
